import pandas as pd
import matplotlib.pyplot as plt
from pathlib import Path

# ----------------------------
# 1. LOAD DATA
# ----------------------------
file_path = Path.home() / "Downloads" / "donor_data.csv"
df = pd.read_csv(file_path)

# ----------------------------
# 2. CLEAN COLUMN NAMES
# ----------------------------
df.columns = (
    df.columns.str.strip()
    .str.lower()
    .str.replace(" ", "_")
    .str.replace("(", "", regex=False)
    .str.replace(")", "", regex=False)
)

print("Cleaned columns:", df.columns.tolist())

donors = df.copy()

# ----------------------------
# 3. AUTO-DETECT IMPORTANT COLUMNS
# ----------------------------
gift_matches = [col for col in donors.columns if "total" in col and "gift" in col]
num_matches = [col for col in donors.columns if "number" in col and "gift" in col]
date_matches = [col for col in donors.columns if "date" in col and "gift" in col]

if not gift_matches:
    raise ValueError("Could not find a total gifts column.")
if not num_matches:
    raise ValueError("Could not find a number of gifts column.")
if not date_matches:
    date_matches = [col for col in donors.columns if "date" in col]

if not date_matches:
    raise ValueError("Could not find a date column.")

gift_col = gift_matches[0]
num_col = num_matches[0]
date_col = date_matches[0]

print("Using columns:")
print("Total gifts column:", gift_col)
print("Number of gifts column:", num_col)
print("Date column:", date_col)

# ----------------------------
# 4. CLEAN DATA
# ----------------------------
donors[gift_col] = (
    donors[gift_col]
    .astype(str)
    .str.replace("$", "", regex=False)
    .str.replace(",", "", regex=False)
    .str.strip()
)

donors[gift_col] = pd.to_numeric(donors[gift_col], errors="coerce")
donors[num_col] = pd.to_numeric(donors[num_col], errors="coerce").fillna(0)
donors[date_col] = pd.to_datetime(donors[date_col], errors="coerce")

# Optional: replace pandas NA values in object columns with actual missing values
donors = donors.replace({"<NA>": pd.NA, "Unknown": "Unknown"})

# ----------------------------
# 5. DONOR CATEGORIZATION
# ----------------------------
def categorize_size(x):
    if pd.isna(x):
        return "Unknown"
    elif x >= 100000:
        return "Major"
    elif x >= 10000:
        return "Mid-Level"
    elif x >= 1000:
        return "General"
    elif x > 0:
        return "Small"
    else:
        return "None"

def categorize_activity(row):
    if row[num_col] >= 3:
        return "Highly Active"
    elif row[num_col] >= 1:
        return "Active"
    elif pd.notna(row[date_col]):
        return "Lapsed"
    else:
        return "Unknown"

donors["donor_size"] = donors[gift_col].apply(categorize_size)
donors["donor_activity"] = donors.apply(categorize_activity, axis=1)

# ----------------------------
# 6. SUMMARY TABLES
# ----------------------------
size_table = donors["donor_size"].value_counts(dropna=False).reset_index()
size_table.columns = ["donor_size", "count"]

activity_table = donors["donor_activity"].value_counts(dropna=False).reset_index()
activity_table.columns = ["donor_activity", "count"]

giving_table = (
    donors[~donors["donor_size"].isin(["Unknown"])]
    .groupby("donor_size", dropna=False)[gift_col]
    .sum()
    .reset_index()
    .sort_values(by=gift_col, ascending=False)
)

cross_tab = pd.crosstab(donors["donor_size"], donors["donor_activity"])

print("\nDonor Size Table:")
print(size_table)

print("\nDonor Activity Table:")
print(activity_table)

print("\nTotal Giving by Donor Size:")
print(giving_table)

print("\nCross Tab:")
print(cross_tab)

# ----------------------------
# 7. PREP CHART DATA
# remove Unknown, None, and missing values from charts
# ----------------------------
exclude_categories = ["Unknown", "None", "<NA>"]

size_chart_data = donors["donor_size"].dropna()
size_chart_data = size_chart_data[~size_chart_data.isin(exclude_categories)]
size_counts = size_chart_data.value_counts()

activity_chart_data = donors["donor_activity"].dropna()
activity_chart_data = activity_chart_data[~activity_chart_data.isin(exclude_categories)]
activity_counts = activity_chart_data.value_counts()

giving_chart_table = giving_table[~giving_table["donor_size"].isin(exclude_categories)]

# ----------------------------
# 8. PIE CHARTS
# ----------------------------
if not size_counts.empty:
    plt.figure(figsize=(7, 7))
    size_counts.plot(kind="pie", autopct="%1.1f%%")
    plt.title("Donor Size Distribution")
    plt.ylabel("")
    plt.tight_layout()
    plt.show()

if not activity_counts.empty:
    plt.figure(figsize=(7, 7))
    activity_counts.plot(kind="pie", autopct="%1.1f%%")
    plt.title("Donor Activity Distribution")
    plt.ylabel("")
    plt.tight_layout()
    plt.show()

# ----------------------------
# 9. BAR CHARTS
# ----------------------------
if not size_counts.empty:
    plt.figure(figsize=(8, 5))
    size_counts.plot(kind="bar")
    plt.title("Donors by Size")
    plt.xlabel("Donor Size")
    plt.ylabel("Count")
    plt.xticks(rotation=45)
    plt.tight_layout()
    plt.show()

if not activity_counts.empty:
    plt.figure(figsize=(8, 5))
    activity_counts.plot(kind="bar")
    plt.title("Donors by Activity")
    plt.xlabel("Donor Activity")
    plt.ylabel("Count")
    plt.xticks(rotation=45)
    plt.tight_layout()
    plt.show()

if not giving_chart_table.empty:
    plt.figure(figsize=(8, 5))
    plt.bar(giving_chart_table["donor_size"], giving_chart_table[gift_col])
    plt.title("Total Giving by Donor Size")
    plt.xlabel("Donor Size")
    plt.ylabel("Total Giving ($)")
    plt.xticks(rotation=45)
    plt.tight_layout()
    plt.show()

# ----------------------------
# 10. SAVE OUTPUTS
# ----------------------------
downloads_folder = Path.home() / "Downloads"

cleaned_file = downloads_folder / "cleaned_donor_data.csv"
size_table_file = downloads_folder / "donor_size_table.csv"
activity_table_file = downloads_folder / "donor_activity_table.csv"
giving_table_file = downloads_folder / "giving_by_size_table.csv"
cross_tab_file = downloads_folder / "donor_crosstab.csv"

donors.to_csv(cleaned_file, index=False)
size_table.to_csv(size_table_file, index=False)
activity_table.to_csv(activity_table_file, index=False)
giving_table.to_csv(giving_table_file, index=False)
cross_tab.to_csv(cross_tab_file)

print("\nFiles saved to Downloads:")
print(cleaned_file)
print(size_table_file)
print(activity_table_file)
print(giving_table_file)
print(cross_tab_file)
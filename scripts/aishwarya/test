# donor_analysis.py

import pandas as pd
import matplotlib.pyplot as plt
from pathlib import Path

file_path = Path(__file__).resolve().parents[2] / "app" / "data" / "donor_data.csv"
df = pd.read_csv(file_path)


# Make a copy so the original is preserved
donors = df.copy()

#clean data

# Standardize column names
donors.columns = (
    donors.columns.str.strip()
                  .str.lower()
                  .str.replace(" ", "_")
                  .str.replace("(", "", regex=False)
                  .str.replace(")", "", regex=False)
)

# Preview new column names
print("Columns:", donors.columns.tolist())

# Clean total_gifts_all_time
donors["total_gifts_all_time"] = (
    donors["total_gifts_all_time"]
    .astype(str)
    .str.replace("$", "", regex=False)
    .str.replace(",", "", regex=False)
    .str.strip()
)

donors["total_gifts_all_time"] = pd.to_numeric(
    donors["total_gifts_all_time"], errors="coerce"
)

# Clean number_of_gifts_past_18_months
donors["number_of_gifts_past_18_months"] = pd.to_numeric(
    donors["number_of_gifts_past_18_months"], errors="coerce"
).fillna(0)

# Clean last_gift_date
donors["last_gift_date"] = pd.to_datetime(
    donors["last_gift_date"], errors="coerce"
)

# Standardize text columns
text_cols = ["city", "state", "postcode", "country"]
for col in text_cols:
    if col in donors.columns:
        donors[col] = donors[col].astype(str).str.strip()

# Replace obvious placeholders / invalid text with NaN
donors = donors.replace({"nan": pd.NA, "None": pd.NA, "": pd.NA})

#donor categorization

# A. Categorize by total giving
def donor_size_category(amount):
    if pd.isna(amount):
        return "Unknown"
    elif amount >= 100000:
        return "Major Donor"
    elif amount >= 10000:
        return "Mid-Level Donor"
    elif amount >= 1000:
        return "General Donor"
    elif amount > 0:
        return "Small Donor"
    else:
        return "No Giving History"

donors["donor_size_category"] = donors["total_gifts_all_time"].apply(donor_size_category)

# B. Categorize by recent activity
def donor_activity_category(row):
    gifts_18m = row["number_of_gifts_past_18_months"]
    last_date = row["last_gift_date"]

    if gifts_18m >= 3:
        return "Highly Active"
    elif gifts_18m >= 1:
        return "Active"
    elif pd.notna(last_date):
        return "Lapsed"
    else:
        return "No Recorded Activity"

donors["donor_activity_category"] = donors.apply(donor_activity_category, axis=1)

# Optional combined category
donors["combined_category"] = (
    donors["donor_size_category"] + " - " + donors["donor_activity_category"]
)

#summary tables

# Table 1: Donor size counts
size_table = (
    donors["donor_size_category"]
    .value_counts(dropna=False)
    .rename_axis("donor_size_category")
    .reset_index(name="count")
)

# Table 2: Donor activity counts
activity_table = (
    donors["donor_activity_category"]
    .value_counts(dropna=False)
    .rename_axis("donor_activity_category")
    .reset_index(name="count")
)

# Table 3: Total dollars by donor size
giving_by_size = (
    donors.groupby("donor_size_category", dropna=False)["total_gifts_all_time"]
    .sum()
    .reset_index()
    .sort_values(by="total_gifts_all_time", ascending=False)
)

# Table 4: Cross-tab of donor size x activity
cross_tab = pd.crosstab(
    donors["donor_size_category"],
    donors["donor_activity_category"]
)

print("\nDonor Size Table")
print(size_table)

print("\nDonor Activity Table")
print(activity_table)

print("\nTotal Giving by Donor Size")
print(giving_by_size)

print("\nCross Tab: Size x Activity")
print(cross_tab)

#saved clean data & tables

output_folder = Path("donor_outputs")
output_folder.mkdir(exist_ok=True)

donors.to_csv(output_folder / "cleaned_donor_data.csv", index=False)
size_table.to_csv(output_folder / "donor_size_table.csv", index=False)
activity_table.to_csv(output_folder / "donor_activity_table.csv", index=False)
giving_by_size.to_csv(output_folder / "giving_by_size.csv", index=False)
cross_tab.to_csv(output_folder / "donor_size_activity_crosstab.csv")

# pie charts

# Pie chart: donor size distribution
plt.figure(figsize=(8, 8))
donors["donor_size_category"].value_counts().plot(
    kind="pie",
    autopct="%1.1f%%",
    ylabel=""
)
plt.title("Donor Size Distribution")
plt.tight_layout()
plt.savefig(output_folder / "pie_donor_size_distribution.png")
plt.show()

# Pie chart: donor activity distribution
plt.figure(figsize=(8, 8))
donors["donor_activity_category"].value_counts().plot(
    kind="pie",
    autopct="%1.1f%%",
    ylabel=""
)
plt.title("Donor Activity Distribution")
plt.tight_layout()
plt.savefig(output_folder / "pie_donor_activity_distribution.png")
plt.show()

# bar charts

# Bar chart: count of donors by size
plt.figure(figsize=(10, 6))
donors["donor_size_category"].value_counts().plot(kind="bar")
plt.title("Number of Donors by Size Category")
plt.xlabel("Donor Size Category")
plt.ylabel("Number of Donors")
plt.xticks(rotation=45, ha="right")
plt.tight_layout()
plt.savefig(output_folder / "bar_donor_size_counts.png")
plt.show()

# Bar chart: total giving by donor size
plt.figure(figsize=(10, 6))
giving_by_size.plot(
    x="donor_size_category",
    y="total_gifts_all_time",
    kind="bar",
    legend=False
)
plt.title("Total Gifts by Donor Size Category")
plt.xlabel("Donor Size Category")
plt.ylabel("Total Gifts ($)")
plt.xticks(rotation=45, ha="right")
plt.tight_layout()
plt.savefig(output_folder / "bar_total_giving_by_size.png")
plt.show()

# Bar chart: donor activity
plt.figure(figsize=(10, 6))
donors["donor_activity_category"].value_counts().plot(kind="bar")
plt.title("Donor Activity Categories")
plt.xlabel("Activity Category")
plt.ylabel("Number of Donors")
plt.xticks(rotation=45, ha="right")
plt.tight_layout()
plt.savefig(output_folder / "bar_donor_activity_counts.png")
plt.show()

#top states table

if "state" in donors.columns:
    top_states = (
        donors["state"]
        .value_counts(dropna=False)
        .head(10)
        .rename_axis("state")
        .reset_index(name="count")
    )
    print("\nTop 10 States")
    print(top_states)
    top_states.to_csv(output_folder / "top_10_states.csv", index=False)

    plt.figure(figsize=(10, 6))
    top_states.plot(x="state", y="count", kind="bar", legend=False)
    plt.title("Top 10 States by Number of Donors")
    plt.xlabel("State")
    plt.ylabel("Number of Donors")
    plt.xticks(rotation=45, ha="right")
    plt.tight_layout()
    plt.savefig(output_folder / "bar_top_10_states.png")
    plt.show()

print(f"\nDone. Cleaned files, tables, and charts were saved in: {output_folder.resolve()}")
